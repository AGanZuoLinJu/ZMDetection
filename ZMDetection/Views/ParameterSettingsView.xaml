<UserControl x:Class="ZMDetection.Views.ParameterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <StackPanel Margin="24,0"
                        VerticalAlignment="Center">
                <TextBlock Text="参数设置"
                           FontSize="20"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="10"
                    Style="{StaticResource ParameterTabControlStyle}"
                    SelectedIndex="{Binding SelectedIndex, Mode=OneWayToSource}">
            <TabItem Header="机种参数"
                     Style="{StaticResource ParameterTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ParameterCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前机种"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding RecipeNames}"
                                          SelectedValue="{Binding CurrentRecipeName}"
                                          Style="{StaticResource ParameterComboBoxStyle}"/>
                                <Button Content="&#xE710;" Width="25" Height="25" Grid.Column="2" Margin="10,0" Command="{Binding AddRecipeCommand}">
                                    <Button.Resources>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                            <Setter Property="Width" Value="25" />
                                            <Setter Property="MinWidth" Value="25" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                                            <Setter Property="FontSize" Value="10" />
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="视觉参数"
                     Style="{StaticResource ParameterTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ParameterCardStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Grid Margin="0,10,20,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="缺陷长"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding DefectLong, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>

                            <Grid Margin="10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="缺陷宽"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding DefectWidth, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>

                            <Grid Margin="20,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="缺陷高"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding DefectHeight, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="通讯参数"
                     Style="{StaticResource ParameterTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ParameterCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PLC IP 地址"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding PlcIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PLC 端口"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding PlcPort, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MES 监听端口"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding MesPort, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="硬件参数"
                     Style="{StaticResource ParameterTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ParameterCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="光源亮度"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding LightSource, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="0 - 255"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相机曝光时间"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding CameraExposureTime, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="μs"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相机增益"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding CameraGain, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相机 X 标定"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding CameraXCalibration, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="mm/pixel"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="300" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="相机 Y 标定"
                                           Style="{StaticResource ParameterLabelStyle}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding CameraYCalibration, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource ParameterTextBoxStyle}" />
                                <TextBlock Grid.Column="2"
                                           Text="mm/pixel"
                                           Style="{StaticResource ParameterUnitStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="保存参数"
                            Command="{Binding SaveCommand}"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="点击保存参数"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
