<Window x:Class="ZMDetection.Views.AddNewRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZMDetection.Views"
        mc:Ignorable="d"
        Title="添加机种" Height="230" Width="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <Border Background="#FFFFFF"
            BorderBrush="#C9D5E5"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="18,0,8,0">
                    <TextBlock Text="添加机种"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Right"
                            Click="CancelButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="34,24,34,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="机种名"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           Margin="2,0,0,6" />
                <TextBox Grid.Row="1"
                         Text="{Binding NewRecipeName, UpdateSourceTrigger=PropertyChanged}"
                         Height="38"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         x:Name="RecipeNameTextBox" />
                <TextBlock Grid.Row="2"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource NgBrush}"
                           FontSize="12"
                           Margin="2,10,0,0"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10">
                    <Button Content="取消"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button Content="添加"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsDefault="True"
                            Command="{Binding AddNewRecipeCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
