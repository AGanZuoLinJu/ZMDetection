<UserControl x:Class="ZMDetection.Views.ProductionStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="1.05*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource StatisticsToolbarStyle}" Margin="0,0,0,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="生产统计面板"
                               FontSize="19"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="日期"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource StatisticsDatePickerStyle}"/>
                    <Button Content="今天"
                            Command="{Binding TodayCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="64"
                            Width="64"
                            Height="25" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatisticsMetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="生产总量" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatisticsMetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="OK 数量" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding OkCount, StringFormat={}{0:N0}}" Foreground="{StaticResource OkBrush}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatisticsMetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="NG 数量" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding NgCount, StringFormat={}{0:N0}}" Foreground="{StaticResource NgBrush}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatisticsMetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="缺陷数量" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding DefectCount, StringFormat={}{0:N0}}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatisticsMetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="良率" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding YieldRate, StringFormat={}{0:N2}%}" Foreground="{StaticResource PrimaryBrush}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="5" Style="{StaticResource StatisticsMetricCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="平均节拍" Style="{StaticResource StatisticsMetricLabelStyle}" />
                    <TextBlock Text="{Binding AverageCycleTime, StringFormat={}{0:N0} ms}" Style="{StaticResource StatisticsMetricValueStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource StatisticsChartCardStyle}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="产量统计" Style="{StaticResource StatisticsChartTitleStyle}" />
                    <Grid Grid.Row="1">
                        <lvc:PieChart Series="{Binding DailyResultSeries}"
                                      LegendPosition="Hidden"
                                      InitialRotation="-90"
                                      MaxAngle="360" />
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0}}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="总量"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StatisticsChartCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="缺陷统计" Style="{StaticResource StatisticsChartTitleStyle}" />
                    <Grid Grid.Row="1">
                        <lvc:CartesianChart Series="{Binding DefectSeries}"
                                            XAxes="{Binding DefectXAxes}"
                                            YAxes="{Binding DefectYAxes}"
                                            LegendPosition="Hidden"
                                            Style="{StaticResource DefectChartVisibilityStyle}" />
                        <TextBlock Text="当天暂无缺陷数据"
                                   Style="{StaticResource DefectEmptyStateStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource StatisticsChartCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="最近 7 天产量与良率"
                               Style="{StaticResource StatisticsChartTitleStyle}" />
                    <TextBlock Text="（所选日期及之前 6 天）"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               Margin="8,2,0,0" />
                </StackPanel>
                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding TrendSeries}"
                                    XAxes="{Binding TrendXAxes}"
                                    YAxes="{Binding TrendYAxes}"
                                    LegendPosition="Top" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
