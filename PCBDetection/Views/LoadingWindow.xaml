<Window x:Class="PCBDetection.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="620"
        Height="350"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="True">
    <Border Background="#FFFFFF"
            BorderBrush="#C9D5E5"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="8"
                              Opacity="0.24"
                              Color="#172033" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#2563EB"
                    CornerRadius="14,14,0,0" />

            <Grid Grid.Row="1" Margin="42,32,42,34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="66"
                            Height="66"
                            CornerRadius="12"
                            Background="#2563EB"
                            Margin="0,0,20,0">
                        <TextBlock Text="PCB"
                                   Foreground="#FFFFFF"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding WindowTitle}"
                                   Foreground="#172033"
                                   FontSize="27"
                                   FontWeight="Bold" />
                        <TextBlock Text="Machine Vision Inspection System"
                                   Foreground="#667085"
                                   FontSize="13"
                                   Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <DockPanel Margin="0,0,0,9">
                        <TextBlock Text="{Binding CurrentStep}"
                                   Foreground="#2563EB"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ProgressValue, StringFormat={}{0:N0}%}"
                                   Foreground="#475467"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                    </DockPanel>
                    <ProgressBar Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}"
                                 Foreground="#2563EB"
                                 Background="#E5EAF1"
                                 />
                    <TextBlock Text="{Binding StatusMessage}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,12,0,0"
                               Style="{StaticResource LoadingStatusTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="{Binding OperationDescription}"
                           Foreground="#98A2B3"
                           FontSize="12" />
            </Grid>
        </Grid>
    </Border>
</Window>
