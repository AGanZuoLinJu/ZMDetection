<UserControl x:Class="PCBDetection.Views.DetectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:halcon="clr-namespace:HalconDotNet;assembly=halcondotnet"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid Background="#F8F8F8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="560" />
            <ColumnDefinition Width="308" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" MinHeight="330" />
                <RowDefinition Height="176" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="产品型号"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentRecipe}"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{Binding InspectionButtonText}"
                            Command="{Binding ToggleInspectionCommand}"
                            Style="{StaticResource InspectionToggleButtonStyle}"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Camera viewer -->
            <Grid Grid.Row="1" Margin="12">
                <Border Background="LightGray"
                        BorderBrush="#343434"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <halcon:HSmartWindowControlWPF
                        x:Name="mainHalconWindow"
                        HKeepAspectRatio="True"
                        HDoubleClickToFitContent="True">
                        <halcon:HIconicDisplayObjectWPF IconicObject="{Binding DisplayMainImage, Mode=OneWay}" />
                    </halcon:HSmartWindowControlWPF>
                </Border>
            </Grid>

            <!-- Fixed operation log -->
            <Border Grid.Row="2"
                    Style="{StaticResource WorkbenchPanelStyle}"
                    Margin="12,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="14,0">
                            <TextBlock Text="运行 / 通信日志"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="清空"
                                    FontSize="12"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="30"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Command="{Binding ClearLogViewCommand}"/>
                        </Grid>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LogItems}"
                             Style="{StaticResource OperationLogListStyle}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12">
                    <Border Style="{StaticResource SideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="当前产品" Style="{StaticResource SideCardTitleStyle}" />
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="产品 ID" Style="{StaticResource KeyLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentBoardId}"
                                           FontFamily="Consolas"
                                           Style="{StaticResource KeyValueStyle}" />
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderBrushSoft}" />
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="产品型号" Style="{StaticResource KeyLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CurrentRecipe}"
                                           Style="{StaticResource KeyValueStyle}" />
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderBrushSoft}" />
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="检测面" Style="{StaticResource KeyLabelStyle}" />
                                <TextBlock Grid.Column="1" Text="A 面" Style="{StaticResource KeyValueStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="本次检测结果"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding InspectionResult}"
                                       Style="{StaticResource ResultTextStyle}"
                                       Margin="0,5"
                                       FontSize="100"
                                       FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="发现 " Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding DefectCount}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock Text=" 处缺陷 · 耗时 " Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock Text="{Binding CycleTime, StringFormat={}{0:N0} ms}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SideCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="180" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="缺陷明细"
                                           FontWeight="SemiBold" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding DefectCount}"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Defects}"
                                      Style="{StaticResource DefectDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="缺陷名"
                                                        Binding="{Binding Name}"
                                                        Width="56" />
                                    <DataGridTextColumn Header="X"
                                                        Binding="{Binding DefectX}"
                                                        Width="28" />
                                    <DataGridTextColumn Header="Y"
                                                        Binding="{Binding DefectY}"
                                                        Width="28" />
                                    <DataGridTextColumn Header="长"
                                                        Binding="{Binding Width}"
                                                        Width="28" />
                                    <DataGridTextColumn Header="宽"
                                                        Binding="{Binding Height}"
                                                        Width="28" />
                                    <DataGridTextColumn Header="面积"
                                                        Binding="{Binding Area}"
                                                        Width="42" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Grid.Row="1"
                                       Text="暂无缺陷数据"
                                       Style="{StaticResource EmptyDefectTextStyle}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SideCardStyle}">
                        <StackPanel>
                            <TextBlock Text="当前班次产量" Style="{StaticResource SideCardTitleStyle}" />
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="62" />
                                    <RowDefinition Height="62" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="检测总数" Style="{StaticResource CompactStatLabelStyle}" />
                                    <TextBlock Text="{Binding TotalCount}" Style="{StaticResource CompactStatValueStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="OK" Style="{StaticResource CompactStatLabelStyle}" />
                                    <TextBlock Text="{Binding OkCount}"
                                               Foreground="{StaticResource OkBrush}"
                                               Style="{StaticResource CompactStatValueStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="NG" Style="{StaticResource CompactStatLabelStyle}" />
                                    <TextBlock Text="{Binding NgCount}"
                                               Foreground="{StaticResource NgBrush}"
                                               Style="{StaticResource CompactStatValueStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="节拍" Style="{StaticResource CompactStatLabelStyle}" />
                                    <TextBlock Text="{Binding CycleTime, StringFormat={}{0:N1}ms}"
                                               Style="{StaticResource CompactStatValueStyle}" />
                                </StackPanel>
                            </Grid>
                            <Border Height="1"
                                    Background="{StaticResource BorderBrushSoft}"
                                    Margin="0,4,0,12" />
                            <Grid Margin="0,0,0,7">
                                <TextBlock Text="直通率" FontSize="12" />
                                <TextBlock Text="{Binding YieldRate, StringFormat={}{0:N1}%}"
                                           FontFamily="Consolas"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <ProgressBar Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding YieldRate, Mode=OneWay}"
                                         Foreground="{StaticResource OkBrush}"
                                         Background="{StaticResource BorderBrushSoft}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
