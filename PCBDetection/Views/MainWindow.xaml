<Window x:Class="PCBDetection.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:PCBDetection.ViewModels"
        Title="{Binding ApplicationTitle}"
        Height="760"
        Width="1280"
        MinHeight="680"
        MinWidth="1120"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="14"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowState="Maximized">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Windows title bar -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                    <Border Width="24"
                            Height="24"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="6"
                            Margin="0,0,10,0">
                        <TextBlock Text="▣"
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="ZM-PCB检测平台"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="v1.0.0"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="10,1,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton"
                            Content="&#xE922;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeButton_Click" />
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource CloseTitleBarButtonStyle}"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Primary navigation -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="生产"
                               Style="{StaticResource SidebarSectionLabelStyle}" />
                    <RadioButton Content="实时检测"
                                 Tag="&#xE9D9;"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsDetectionSelected, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="DetectionView"
                                 Style="{StaticResource NavigationButtonStyle}" />
                    <RadioButton Content="统计报表"
                                 Tag="&#xE9D2;"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsStatisticsSelected, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="ProductionStatisticsView"
                                 Style="{StaticResource NavigationButtonStyle}" />

                    <TextBlock Text="配置"
                               Style="{StaticResource SidebarSectionLabelStyle}" />
                    <RadioButton Content="参数设置"
                                 Tag="&#xE713;"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsParametersSelected, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="ParameterSettingsView"
                                 Style="{StaticResource NavigationButtonStyle}" />
                    <RadioButton Content="系统设置"
                                 Tag="&#xE77B;"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsSystemSelected, Mode=OneWay}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="SystemSettingsView"
                                 Style="{StaticResource NavigationButtonStyle}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="8,12,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource BorderBrushSoft}" />
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="32"
                                Height="32"
                                Background="#F1F1F1"
                                CornerRadius="16">
                            <TextBlock Text="管"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="管理员"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock Text="设备维护权限"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="10" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        prism:RegionManager.RegionName="MainContentRegion" />

        <!-- Persistent system status -->
        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        Margin="12,0"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            ToolTip="{Binding Status.CameraStatus}">
                    <TextBlock Text="相机" Style="{StaticResource StatusTextStyle}" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             Fill="{Binding Status.CameraStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            ToolTip="{Binding Status.PlcStatus}">
                    <TextBlock Text="PLC" Style="{StaticResource StatusTextStyle}" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             Fill="{Binding Status.PlcStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            ToolTip="{Binding Status.AiStatus}">
                    <TextBlock Text="AI" Style="{StaticResource StatusTextStyle}" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             Fill="{Binding Status.AiStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            ToolTip="{Binding Status.LightStatus}">
                    <TextBlock Text="光源" Style="{StaticResource StatusTextStyle}" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             Fill="{Binding Status.LightStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Margin="16,0,0,0"
                            ToolTip="{Binding Status.MesStatus}">
                    <TextBlock Text="MES" Style="{StaticResource StatusTextStyle}" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             Fill="{Binding Status.MesStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
