<Window x:Class="PCBDetection.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding ApplicationTitle}"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        Background="#F4F7FB"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowState="Maximized">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE5EF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="OkBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="NgBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="WarningBrush" Color="#EA580C" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EAF2FF" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D8E7FF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DC2626" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B91C1C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="4"
                            Background="{StaticResource PrimaryBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="PCB"
                                   Foreground="#FFFFFF"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="PCB检测平台"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton"
                            Content="&#xE922;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeButton_Click" />
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource CloseTitleBarButtonStyle}"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelStyle}"
                    Padding="20,16"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42"
                                Height="42"
                                CornerRadius="8"
                                Background="{StaticResource PrimaryBrush}"
                                Margin="0,0,14,0">
                            <TextBlock Text="PCB"
                                       Foreground="#FFFFFF"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding ApplicationTitle}"
                                       FontSize="24"
                                       FontWeight="Bold" />
                            <TextBlock Text="Machine vision inspection dashboard"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="13"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Background="#EAF2FF"
                                BorderBrush="#BBD2FF"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12,5"
                                Margin="24,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding InspectionStatus}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Start"
                                Command="{Binding StartInspectionCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="Stop"
                                Command="{Binding StopInspectionCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Reset"
                                Command="{Binding ResetStatisticsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Capture"
                                Command="{Binding LoadImageCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelStyle}"
                        Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Station Status"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Device and recipe summary"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,18" />

                        <TextBlock Text="Camera"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding CameraStatus}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="PLC"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding PlcStatus}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="MES"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding MesStatus}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="Light"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding LightStatus}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="AI"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding AiStatus}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="Current Board"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding CurrentBoardId}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,12" />

                        <TextBlock Text="Recipe"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Text="{Binding CurrentRecipe}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,18" />

                        <TextBlock Text="Detection Steps"
                                   Style="{StaticResource MetricLabelStyle}" />
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="1. Alignment" Margin="0,4" />
                            <TextBlock Text="2. Solder joint check" Margin="0,4" />
                            <TextBlock Text="3. Component presence" Margin="0,4" />
                            <TextBlock Text="4. Defect classification" Margin="0,4" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource PanelStyle}"
                        Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="PCB Preview"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding PreviewMessage}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding CycleTime, StringFormat={}{0:N0} ms}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top" />
                        </DockPanel>

                        <Border Grid.Row="1"
                                Background="#EDF2F7"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="6"
                                ClipToBounds="True">
                            <Grid Margin="24">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#0F172A"
                                        CornerRadius="6"
                                        BorderBrush="#334155"
                                        BorderThickness="1">
                                    <Grid Margin="28">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Background="#1D4ED8" Margin="4" />
                                        <Border Grid.Row="0" Grid.Column="1" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="0" Grid.Column="2" Background="#475569" Margin="4" />
                                        <Border Grid.Row="0" Grid.Column="3" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="0" Grid.Column="4" Background="#475569" Margin="4" />
                                        <Border Grid.Row="0" Grid.Column="5" Background="#1D4ED8" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="0" Background="#475569" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="1" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="2" Background="#1D4ED8" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="3" Background="#475569" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="4" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="1" Grid.Column="5" Background="#475569" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="0" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="1" Background="#475569" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="2" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="3" Background="#DC2626" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="4" Background="#475569" Margin="4" />
                                        <Border Grid.Row="2" Grid.Column="5" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="0" Background="#1D4ED8" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="1" Background="#475569" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="2" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="3" Background="#475569" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="4" Background="#22C55E" Margin="4" />
                                        <Border Grid.Row="3" Grid.Column="5" Background="#1D4ED8" Margin="4" />

                                        <Border Grid.Row="2"
                                                Grid.Column="3"
                                                BorderBrush="#F87171"
                                                BorderThickness="3"
                                                CornerRadius="4"
                                                Margin="1" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Resolution: 4096 x 3072" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Column="1" Text="Exposure: 2.5 ms" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="Lens: 35 mm" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Inspection Result"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Live production metrics"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,18" />

                        <UniformGrid Columns="2" Rows="2">
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="OK" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock Text="{Binding OkCount}" Foreground="{StaticResource OkBrush}" Style="{StaticResource MetricValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="NG" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock Text="{Binding NgCount}" Foreground="{StaticResource NgBrush}" Style="{StaticResource MetricValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,8,8,0">
                                <StackPanel>
                                    <TextBlock Text="Defects" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock Text="{Binding DefectCount}" Foreground="{StaticResource WarningBrush}" Style="{StaticResource MetricValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Yield" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBlock Text="{Binding YieldRate, StringFormat={}{0:N1}%}" Foreground="{StaticResource PrimaryBrush}" Style="{StaticResource MetricValueStyle}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Background="#F8FAFC"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Cycle Time" Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock Text="{Binding CycleTime, StringFormat={}{0:N0} ms}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0" />
                                <ProgressBar Height="8"
                                             Margin="0,14,0,0"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding CycleTimeProgress, Mode=OneWay, FallbackValue=0, TargetNullValue=0}"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             Background="#E5E7EB" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}"
                    Margin="0,16,0,0"
                    Padding="18,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Operation Log"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Latest events first"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Right" />
                    </DockPanel>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding LogItems}"
                              BorderBrush="{StaticResource BorderBrushSoft}"
                              BorderThickness="1"
                              Background="#FFFFFF">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="150" DisplayMemberBinding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                                <GridViewColumn Header="Level" Width="90" DisplayMemberBinding="{Binding Level}" />
                                <GridViewColumn Header="Message" Width="820" DisplayMemberBinding="{Binding Message}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
